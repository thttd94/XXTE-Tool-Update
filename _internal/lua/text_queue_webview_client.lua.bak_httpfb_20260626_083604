local sys = require("sys")
local webview = require("webview")
local json = require("json")

local SERVERS = { 'http://192.17.1.10:8765', 'http://192.16.1.10:8765', 'http://192.15.1.10:8765', 'http://192.14.1.10:8765', 'http://192.168.9.201:8765' }
local API_PATH = "/api/text/next"
local WV_ID = 73

local html = [[
