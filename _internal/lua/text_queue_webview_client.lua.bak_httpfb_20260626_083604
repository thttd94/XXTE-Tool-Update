local current = {text1='', text2='', text3=''}

local function jsq(s)
  s = tostring(s or '')
  s = string.gsub(s, "\\", "\\\\")
  s = string.gsub(s, "\n", "\\n")
  s = string.gsub(s, "\r", "")
  s = string.gsub(s, "'", "\\'")
  return "'" .. s .. "'"
end

local function set_status(s)
  pcall(webview.eval, "setStatus(" .. jsq(s) .. ");", WV_ID)
end

local function copy_text(s)
  s = tostring(s or '')
  local tmp = "/tmp/text_queue_copy.txt"
  local f = io.open(tmp, "wb")
  if f then
    f:write(s)
    f:close()
    os.execute("pbcopy < " .. tmp)
    set_status("Copied")
    sys.toast("Copied")
  else
    set_status("Copy lỗi")
  end
end

local function http_get(url)
  local tmp = "/tmp/text_queue_next.json"
  os.execute("curl -ks --connect-timeout 2 --max-time 5 \"" .. url .. "\" -o " .. tmp)
  local f = io.open(tmp, "rb")
  if not f then return nil end
  local data = f:read("*a") or ""
  f:close()
  return data
end

local function get_text()
  set_status("Đang lấy...")
  for i=1,#SERVERS do
    local url = tostring(SERVERS[i]) .. API_PATH
    local raw = http_get(url)
    if raw and raw ~= '' then
      local ok, item = pcall(json.decode, raw)
      if ok and type(item)=='table' and item.ok then
        current = item
        pcall(webview.eval, "setTexts(" .. jsq(item.text1) .. "," .. jsq(item.text2) .. "," .. jsq(item.text3) .. ");", WV_ID)
        set_status("OK còn " .. tostring(item.remain or '?'))
        return true
      else
        set_status(raw)
      end
    end
  end
  set_status("Không kết nối được server")
  return false
end

webview.show({id=WV_ID, html=html, x=1, y=1, width=748, height=161, alpha=1.0, corner_radius=12, opaque=false, can_drag=false, ignores_hit=false})
sys.msleep(200)
set_status("Sẵn sàng")

while true do
  local action = tostring(webview.eval('window.__xxt_action || "";', WV_ID) or '')
  if action ~= '' then
    webview.eval('window.__xxt_action="";', WV_ID)
    if action == 'get' then get_text()
    elseif action == 'copy1' then copy_text(current.text1)
    elseif action == 'copy2' then copy_text(current.text2)
    elseif action == 'copy3' then copy_text(current.text3)
    end
  end
  sys.msleep(150)
end
