local sys = require("sys")
local webview = require("webview")
local pasteboard = require("pasteboard")

local WV_ID = 73
local html = [==[
<!doctype html><html><head><meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<style>
html,body{margin:0;padding:0;width:100%;height:100%;background:transparent;overflow:hidden;font-family:-apple-system,BlinkMacSystemFont,sans-serif;-webkit-user-select:none;user-select:none;-webkit-touch-callout:none}
*{-webkit-user-select:none;user-select:none;-webkit-touch-callout:none;-webkit-tap-highlight-color:transparent;box-sizing:border-box}
#bar{width:100%;height:100%;display:flex;flex-direction:column;gap:8px;background:rgba(2,6,23,.86);border-radius:12px;padding:8px;color:white}
#top{display:flex;gap:8px;align-items:center}.row{display:flex;gap:8px;align-items:center}
button{height:38px;border:0;border-radius:10px;padding:0 14px;background:#2563eb;color:#fff;font-size:15px;font-weight:800}
.txt{background:#16a34a;max-width:230px;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;flex:1}
#status{font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1;color:#e5e7eb}.hidden{display:none!important}
</style>
<script>
const SERVERS = ["http://192.17.1.10:8765", "http://192.16.1.10:8765", "http://192.15.1.10:8765", "http://192.14.1.10:8765", "http://192.168.9.201:8765"];
window.__xxt_action='';
window.__xxt_copy='';
function setStatus(s){document.getElementById('status').textContent=String(s||'');}
function actCopy(n){ window.__xxt_copy = window.__texts ? (window.__texts[n] || '') : ''; window.__xxt_action='copy'; return false; }
function showTexts(t){ window.__texts={1:t.text1||'',2:t.text2||'',3:t.text3||''}; document.getElementById('t1').textContent=window.__texts[1]||'Text 1'; document.getElementById('t2').textContent=window.__texts[2]||'Text 2'; document.getElementById('t3').textContent=window.__texts[3]||'Text 3'; document.getElementById('texts').classList.remove('hidden'); }
async function getText(){
 setStatus('Đang lấy...');
 for(const base of SERVERS){
   try{
    setStatus('Thử '+base);
    const r = await fetch(base + '/api/text/next', {cache:'no-store'});
    const j = await r.json();
    if(j && j.ok){ showTexts(j); setStatus('OK còn '+(j.remain ?? '?')); return false; }
    setStatus((j && j.error) ? j.error : 'empty');
   }catch(e){ setStatus('Fail '+base); }
 }
 setStatus('Không kết nối được server');
 return false;
}
</script></head><body>
<div id="bar">
 <div id="top"><button onclick="return getText()">Lấy Text</button><div id="status">Sẵn sàng</div></div>
 <div id="texts" class="row hidden"><button class="txt" id="t1" onclick="return actCopy(1)">Text 1</button><button class="txt" id="t2" onclick="return actCopy(2)">Text 2</button><button class="txt" id="t3" onclick="return actCopy(3)">Text 3</button></div>
</div>
</body></html>
]==]

html = string.gsub(html, "["http://192.17.1.10:8765", "http://192.16.1.10:8765", "http://192.15.1.10:8765", "http://192.14.1.10:8765", "http://192.168.9.201:8765"]", [==[["http://192.17.1.10:8765", "http://192.16.1.10:8765", "http://192.15.1.10:8765", "http://192.14.1.10:8765", "http://192.168.9.201:8765"]]==])
webview.show({id=WV_ID, html=html, x=1, y=1, width=748, height=161, alpha=1.0, corner_radius=12, opaque=false, can_drag=false, ignores_hit=false})
sys.msleep(200)

while true do
  local action = tostring(webview.eval('window.__xxt_action || "";', WV_ID) or '')
  if action == 'copy' then
    local text = tostring(webview.eval('window.__xxt_copy || "";', WV_ID) or '')
    webview.eval('window.__xxt_action=""; window.__xxt_copy="";', WV_ID)
    if text ~= '' then
      pasteboard.write(text)
      pcall(webview.eval, "setStatus('Copied');", WV_ID)
      sys.toast('Copied')
    else
      pcall(webview.eval, "setStatus('Text rỗng');", WV_ID)
    end
  end
  sys.msleep(150)
end
