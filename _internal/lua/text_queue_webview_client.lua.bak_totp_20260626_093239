 <div id="top"><button onclick="return getText()">Lấy Text</button><div id="status">Sẵn sàng</div></div>
 <div id="texts" class="row hidden"><button class="txt" id="t1" onclick="return actCopy(1)">Text 1</button><button class="txt" id="t2" onclick="return actCopy(2)">Text 2</button><button class="txt" id="t3" onclick="return actCopy(3)">Text 3</button></div>
