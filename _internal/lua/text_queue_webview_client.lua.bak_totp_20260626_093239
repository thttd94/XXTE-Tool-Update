<script>
const MACHINE = '798';
const SERVERS = ["http://192.17.1.10:8765", "http://192.16.1.10:8765", "http://192.15.1.10:8765", "http://192.14.1.10:8765", "http://192.168.9.201:8765"];
window.__xxt_action='';
window.__xxt_copy='';
function setStatus(s){document.getElementById('status').textContent=String(s||'');}
function actCopy(n){ window.__xxt_copy = window.__texts ? (window.__texts[n] || '') : ''; window.__xxt_action='copy'; return false; }
function showTexts(t){ window.__texts={1:t.text1||'',2:t.text2||'',3:t.text3||''}; document.getElementById('t1').textContent=window.__texts[1]||'Text 1'; document.getElementById('t2').textContent=window.__texts[2]||'Text 2'; document.getElementById('t3').textContent=window.__texts[3]||'Text 3'; document.getElementById('texts').classList.remove('hidden'); }
async function getText(){
 setStatus('Đang lấy...');
 for(const base of SERVERS){
   try{
    setStatus('Thử '+base);
    const r = await fetch(base + '/api/text/next?machine=' + encodeURIComponent(MACHINE), {cache:'no-store'});
    const j = await r.json();
    if(j && j.ok){ showTexts(j); window.__xxt_last_raw = JSON.stringify(j); window.__xxt_action='save'; setStatus('OK còn '+(j.remain ?? '?')); return false; }
    setStatus((j && j.error) ? j.error : 'empty');
   }catch(e){ setStatus('Fail '+base); }
 }
 setStatus('Không kết nối được server');
